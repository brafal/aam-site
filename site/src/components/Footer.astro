---
import { switchLang, currentLocale, t } from '../data/i18n';
import type { Locale } from '../data/i18n';
import { contact } from '../data/site';

interface Props {
  lang?: Locale;
}

const lang = Astro.props.lang ?? currentLocale(Astro.url.pathname);
const mkUrl = switchLang(Astro.url.pathname, 'mk');
const enUrl = switchLang(Astro.url.pathname, 'en');
---

<footer class="bg-[#111827] text-[#9ca3af]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Col 1: Brand -->
      <div>
        <a href={lang === 'mk' ? '/mk' : '/'}>
          <img
            src="/logo/AAM-logo.png"
            alt="AAM Airport Services"
            width="908"
            height="135"
            class="h-7 w-auto mb-3 brightness-0 invert"
            loading="lazy"
          />
        </a>
        <p class="text-sm">AAM DOOEL Skopje</p>
        <p class="text-sm">Skopje, Macedonia</p>
        <p class="text-sm mt-3 text-[#6b7280]">
          Est. 1992 · Operating since 1995
        </p>
        <p class="text-sm mt-2 text-[#6b7280]">
          Ground handling supervision & station management at Skopje (SKP) and Ohrid (OHD) airports.
        </p>
        <!-- Facebook -->
        <a
          href="https://facebook.com/aamairportservices"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 mt-3 text-[#6b7280] hover:text-white transition-colors text-sm"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
          </svg>
          Facebook
        </a>
      </div>

      <!-- Col 2: Quick Links -->
      <div>
        <p class="text-white font-semibold mb-4 text-sm uppercase tracking-wide">Quick Links</p>
        <nav class="space-y-2 text-sm">
          <p><a href="/services" class="hover:text-white transition-colors">Services</a></p>
          <p><a href="/airports/skp" class="hover:text-white transition-colors">Airports</a></p>
          <p><a href="/about" class="hover:text-white transition-colors">About</a></p>
          <p><a href="/contact" class="hover:text-white transition-colors">Contact</a></p>
          <p><a href="/privacy" class="hover:text-white transition-colors">Privacy</a></p>
          <p><a href="/terms" class="hover:text-white transition-colors">Terms</a></p>
        </nav>
      </div>

      <!-- Col 3: AAM Group -->
      <div>
        <p class="text-white font-semibold mb-4 text-sm uppercase tracking-wide">AAM Group</p>
        <nav class="space-y-2 text-sm">
          <p><a href="/services" class="hover:text-white transition-colors">AAM Airport DOO</a></p>
          <p>
            <a href="https://avio.net.mk" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">
              Avionet — Subsidiary ↗
            </a>
          </p>
          <p class="text-[#6b7280] text-xs mt-1">IATA Agent & BSP Consolidator</p>
        </nav>
      </div>

      <!-- Col 4: Contact -->
      <div>
        <p class="text-white font-semibold mb-4 text-sm uppercase tracking-wide">Contact</p>
        <div class="space-y-2 text-sm">
          <p>
            <a href="tel:+38923117009" class="hover:text-white transition-colors">{contact.phone}</a>
          </p>
          <p>
            <a
              href="#"
              class="em-link hover:text-white transition-colors"
              data-u="aaminfo"
              data-d="aam.com.mk"
              data-em-label="1"
            >&#97;&#97;&#109;&#105;&#110;&#102;&#111;&#64;&#97;&#97;&#109;&#46;&#99;&#111;&#109;&#46;&#109;&#107;</a>
          </p>
          <p class="text-[#6b7280]">Skopje, Macedonia</p>
        </div>

        <!-- Language switcher -->
        <div class="flex items-center gap-1.5 mt-4 text-xs font-mono font-bold">
          <a
            href={enUrl}
            class={`px-2 py-1 rounded transition-colors ${lang === 'en' ? 'text-white bg-white/10' : 'text-[#6b7280] hover:text-white'}`}
          >EN</a>
          <a
            href={mkUrl}
            class={`px-2 py-1 rounded transition-colors ${lang === 'mk' ? 'text-white bg-white/10' : 'text-[#4b5563] cursor-not-allowed'}`}
            title="Macedonian — coming soon"
          >MK</a>
        </div>
      </div>

    </div>

    <div class="border-t border-[#1f2937] mt-10 pt-6 text-xs text-[#6b7280] flex flex-col sm:flex-row justify-between gap-2">
      <p>&copy; {new Date().getFullYear()} AAM DOOEL Skopje. All rights reserved.</p>
      <p>aam.com.mk</p>
    </div>
  </div>
</footer>