<div id="cookie-banner" class="hidden fixed bottom-0 left-0 right-0 bg-white border-t border-slate-200 shadow-lg z-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
    <p class="text-sm text-slate-600">
      {Astro.props.lang === 'mk'
        ? 'Овој веб-сајт користи колачиња за аналитика. Со кликнување на "Прифати" се согласувате со употреба на колачиња.'
        : 'This website uses cookies for analytics. By clicking "Accept" you consent to the use of cookies.'}
    </p>
    <div class="flex items-center gap-3 shrink-0">
      <button id="cookie-reject" class="text-sm font-medium text-slate-500 hover:text-slate-700 px-4 py-2 rounded-md hover:bg-slate-100 transition-colors">
        {Astro.props.lang === 'mk' ? 'Одбиј' : 'Reject'}
      </button>
      <button id="cookie-accept" class="text-sm font-semibold text-white bg-aam-blue px-4 py-2 rounded-md hover:bg-aam-blue-dark transition-colors">
        {Astro.props.lang === 'mk' ? 'Прифати' : 'Accept'}
      </button>
    </div>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('cookie-accept');
  const rejectBtn = document.getElementById('cookie-reject');
  const gaId = window._gaId;

  if (!localStorage.getItem('aam_cookie_consent')) {
    banner?.classList.remove('hidden');
  }

  acceptBtn?.addEventListener('click', () => {
    localStorage.setItem('aam_cookie_consent', 'accepted');
    banner?.classList.add('hidden');
    if (gaId) {
      var s = document.createElement('script');
      s.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
      s.async = true;
      document.head.appendChild(s);
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', gaId);
    }
  });

  rejectBtn?.addEventListener('click', () => {
    localStorage.setItem('aam_cookie_consent', 'rejected');
    banner?.classList.add('hidden');
  });
</script>