---
import { navLinks } from '../data/navigation';
import { currentLocale, switchLang, t } from '../data/i18n';
import type { Locale } from '../data/i18n';

interface Props {
  lang?: Locale;
}

const lang = Astro.props.lang ?? currentLocale(Astro.url.pathname);
const currentPath = Astro.url.pathname;

function isActive(linkPath: string): boolean {
  if (linkPath === '/') return currentPath === '/' || currentPath === '/en';
  return currentPath === linkPath || currentPath.startsWith(linkPath + '/');
}

const mkUrl = switchLang(currentPath, 'mk');
const enUrl = switchLang(currentPath, 'en');
---

<header class="bg-white border-b border-slate-200 sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href={lang === 'mk' ? '/mk' : '/'} class="flex items-center gap-3 shrink-0">
        <img
          src="/logo/AAM-logo.png"
          alt="AAM Airport Services"
          width="908"
          height="135"
          class="h-8 w-auto"
          loading="eager"
        />
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-1">
        <nav class="flex items-center gap-1">
          {navLinks.map(link => (
            <div class="relative group">
              <a
                href={link.path}
                class={`px-3 py-2 text-sm font-semibold transition-colors inline-flex items-center gap-1 ${
                  isActive(link.path)
                    ? 'text-aam-blue'
                    : 'text-slate-600 hover:text-slate-900 rounded-md hover:bg-surface-soft'
                }`}
              >
                {link.label}
                {link.children && (
                  <svg class="w-3 h-3 ml-0.5 opacity-60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M6 9l6 6 6-6"/>
                  </svg>
                )}
              </a>

              {link.children && (
                <div class="absolute top-full left-0 mt-1 bg-white border border-slate-200 rounded-xl shadow-lg py-2 min-w-[260px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
                  {link.children.map(child => (
                    child.label === 'divider' ? (
                      <div class="mx-4 my-2 border-t border-slate-200"></div>
                    ) : (
                      <a
                        href={child.path}
                        class="block px-5 py-2.5 text-sm text-slate-600 hover:text-aam-blue hover:bg-surface-soft transition-colors"
                      >
                        {child.label}
                      </a>
                    )
                  ))}
                </div>
              )}
            </div>
          ))}
        </nav>

        <!-- Phone + Lang + CTA -->
        <div class="flex items-center ml-3 pl-3 border-l border-slate-200 gap-3">
          <a href="tel:+38923117009" class="text-sm font-semibold text-slate-700 hover:text-aam-blue transition-colors whitespace-nowrap">
            +389 2 3117 009
          </a>

          <!-- Language switcher -->
          <div class="flex items-center gap-1 text-xs font-mono font-bold">
            <a
              href={enUrl}
              class={`px-1.5 py-0.5 rounded transition-colors ${lang === 'en' ? 'text-aam-blue bg-aam-blue-light' : 'text-slate-400 hover:text-slate-600'}`}
            >EN</a>
            <a
              href={mkUrl}
              class={`px-1.5 py-0.5 rounded transition-colors ${lang === 'mk' ? 'text-aam-blue bg-aam-blue-light' : 'text-slate-300 cursor-not-allowed'}`}
              title="Macedonian — coming soon"
            >MK</a>
          </div>

          <a href={lang === 'mk' ? '/mk/contact' : '/contact'} class="inline-block bg-aam-blue text-white text-sm font-semibold px-4 py-2 rounded-md hover:bg-aam-blue-dark transition-colors whitespace-nowrap">
            Get in Touch
          </a>
        </div>
      </div>

      <!-- Mobile menu button -->
      <button
        id="menu-btn"
        class="lg:hidden p-2 rounded-md text-slate-600 hover:bg-slate-100 transition-colors"
        aria-label="Toggle navigation"
        aria-expanded="false"
      >
        <svg id="icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <nav id="mobile-menu" class="hidden lg:hidden pb-4 border-t border-slate-100 pt-3">
      {navLinks.map(link => (
        <div>
          <a
            href={link.path}
            class={`block px-3 py-2.5 rounded-md text-sm font-semibold mb-1 transition-colors ${
              isActive(link.path)
                ? 'bg-aam-blue-light text-aam-blue'
                : 'text-slate-600 hover:text-slate-900 hover:bg-surface-soft'
            }`}
          >
            {link.label}
          </a>
          {link.children && (
            <div class="ml-4 mb-2 border-l-2 border-slate-200 pl-4 space-y-0.5">
              {link.children.map(child => (
                child.label === 'divider' ? (
                  <div class="my-1.5 border-t border-slate-200 w-12"></div>
                ) : (
                  <a
                    href={child.path}
                    class="block px-2 py-1.5 rounded text-sm text-slate-500 hover:text-aam-blue hover:bg-surface-soft transition-colors"
                  >
                    {child.label}
                  </a>
                )
              ))}
            </div>
          )}
        </div>
      ))}
      <div class="flex items-center gap-3 px-3 pt-3 border-t border-slate-100 mt-2">
        <a href="tel:+38923117009" class="text-sm font-semibold text-slate-700">+389 2 3117 009</a>
        <a href={lang === 'mk' ? '/mk/contact' : '/contact'} class="inline-block bg-aam-blue text-white text-sm font-semibold px-4 py-2 rounded-md">Get in Touch</a>
        <div class="flex items-center gap-1 text-xs font-mono font-bold ml-auto">
          <a href={enUrl} class={`px-1.5 py-0.5 rounded ${lang === 'en' ? 'text-aam-blue bg-aam-blue-light' : 'text-slate-400'}`}>EN</a>
          <a href={mkUrl} class={`px-1.5 py-0.5 rounded ${lang === 'mk' ? 'text-aam-blue bg-aam-blue-light' : 'text-slate-300 cursor-not-allowed'}`}>MK</a>
        </div>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  function closeMenu() {
    menu?.classList.add('hidden');
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    btn?.setAttribute('aria-expanded', 'false');
  }

  function openMenu() {
    menu?.classList.remove('hidden');
    iconOpen?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
    btn?.setAttribute('aria-expanded', 'true');
  }

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    if (isOpen) { closeMenu(); } else { openMenu(); }
  });

  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>
