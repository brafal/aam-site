---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { timeline } from '../data/site';
import { meta, hero, intro, group, certifications, historyTimeline, closingCta } from '../data/pages/about';
import { defaultLocale } from '../data/i18n';

const lang = defaultLocale;
---

<Layout title={meta.title} description={meta.description} ogImage="/images/airplane-takeoff-clouds.webp">
  <Nav lang={lang} />

  <!-- Hero -->
  <section class="relative h-[400px] bg-slate-900 overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image:url('/images/airplane-takeoff-clouds.webp')"></div>
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 h-full flex items-center">
      <div>
        <span class="inline-block text-xs font-semibold uppercase tracking-[0.22em] text-white bg-white/15 px-4 py-2 rounded-full mb-4">{hero.badge}</span>
        <h1 class="text-4xl md:text-5xl font-bold text-white -tracking-[0.02em] mb-3 max-w-[700px]">{hero.heading}</h1>
        <p class="text-lg text-white/80 max-w-[600px]">{hero.subtext}</p>
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-10 md:py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-[1.05fr_1fr] gap-12 items-stretch">
        <div class="relative rounded-xl overflow-hidden min-h-[460px] bg-gradient-to-br from-[#0F2440] to-[#1B365D]">
          <div class="absolute inset-0 bg-cover bg-center" style={`background-image:url('${intro.image}')`}></div>
          <div class="absolute inset-0 bg-gradient-to-t from-[#0F2440]/85 via-[#0F2440]/20 to-transparent"></div>
          <div class="absolute left-6 bottom-6 bg-white rounded-xl px-5 py-4 shadow-lg flex items-center gap-3 z-10">
            <span class="text-3xl font-bold text-aam-blue">{intro.badge}</span>
            <span class="text-sm font-medium text-slate-600 leading-tight whitespace-pre-line">{intro.badgeLabel}</span>
          </div>
        </div>
        <div class="flex flex-col justify-center py-6">
          <span class="inline-block text-xs font-semibold uppercase tracking-widest text-aam-blue bg-aam-blue-light px-3 py-1.5 rounded-full mb-4 w-fit">
            {intro.eyebrow}
          </span>
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 -tracking-[0.015em] mb-5">{intro.heading}</h2>
          {intro.paragraphs.map(p => <p class="text-base text-slate-600 leading-relaxed mb-3">{p}</p>)}
          <div class="grid grid-cols-3 gap-3 mt-4">
            {intro.facts.map(f => (
              <div class="bg-white border border-slate-200 rounded-lg px-4 py-3">
                <div class="text-xs uppercase tracking-[0.12em] text-slate-400 font-semibold mb-1">{f.label}</div>
                <div class="text-sm font-semibold text-slate-800 leading-tight">{f.value}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Group Cards -->
  <section class="py-10 md:py-12 bg-surface-soft">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl font-bold text-slate-900 mb-2">{group.heading}</h2>
      <p class="text-sm text-slate-400 font-mono mb-10">{group.address}</p>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white border border-slate-200 rounded-xl p-7 flex flex-col">
          <h3 class="text-xl font-bold text-slate-900 mb-1">{group.aamDoel.fullNameLatin}</h3>
          <p class="text-sm text-slate-500 mb-1">{group.aamDoel.fullName}</p>
          <p class="text-xs tracking-[0.14em] text-slate-400 uppercase font-semibold font-mono mb-1">{group.aamDoel.role}</p>
          {group.aamDoel.manager && <p class="text-sm font-medium text-slate-700 mb-3">{group.aamDoel.manager}</p>}
          <div class="space-y-1 text-sm text-slate-500 mb-6">
            <p class="font-mono text-xs text-slate-400">{group.aamDoel.embs}</p>
            <p class="font-mono text-xs text-slate-400">{group.aamDoel.edb}</p>
          </div>
        </div>
        <div class="bg-aam-blue text-white rounded-xl p-7 flex flex-col">
          <h3 class="text-xl font-bold text-white mb-1">{group.aamAirport.fullNameLatin}</h3>
          <p class="text-sm text-white/60 mb-1">{group.aamAirport.fullName}</p>
          <p class="text-xs tracking-[0.14em] text-aam-gold uppercase font-semibold font-mono mb-1">{group.aamAirport.role}</p>
          {group.aamAirport.manager && <p class="text-sm font-medium text-white/80 mb-3">{group.aamAirport.manager}</p>}
          <div class="space-y-1 text-sm mb-6">
            <p class="font-mono text-xs text-white/50">{group.aamAirport.embs}</p>
            <p class="font-mono text-xs text-white/50">{group.aamAirport.edb}</p>
          </div>
          <a href="/services" class="mt-auto inline-flex items-center gap-2 text-aam-gold font-semibold text-base hover:underline">{group.aamAirport.cta} →</a>
        </div>
        <div class="bg-white border border-slate-200 rounded-xl p-7 flex flex-col">
          <h3 class="text-xl font-bold text-slate-900 mb-1">{group.avionet.fullNameLatin}</h3>
          <p class="text-sm text-slate-500 mb-1">{group.avionet.fullName}</p>
          <p class="text-xs tracking-[0.14em] text-slate-400 uppercase font-semibold font-mono mb-1">{group.avionet.role}</p>
          {group.avionet.manager && <p class="text-sm font-medium text-slate-700 mb-3">{group.avionet.manager}</p>}
          <div class="space-y-1 text-sm mb-6">
            <p class="font-mono text-xs text-slate-400">{group.avionet.embs}</p>
            <p class="font-mono text-xs text-slate-400">{group.avionet.edb}</p>
          </div>
          <a href="https://avio.net.mk" target="_blank" rel="noopener noreferrer" class="mt-auto inline-flex items-center gap-2 text-aam-blue font-semibold text-base hover:underline">{group.avionet.cta} ↗</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="py-10 md:py-12 bg-surface-soft">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl font-bold text-slate-900 mb-6">{certifications.heading}</h2>
      {certifications.items.map(cert => (
        <div class="flex items-center gap-6 bg-white border border-slate-200 rounded-xl p-6">
          <a href={cert.certificate} target="_blank" rel="noopener noreferrer" class="shrink-0">
            <img src={cert.logo} alt={cert.fullName} class="h-16 w-auto object-contain" loading="lazy" />
          </a>
          <div>
            <p class="font-semibold text-slate-900 mb-1">{cert.fullName}</p>
            <p class="text-sm text-slate-500">{cert.desc}</p>
            <a href={cert.certificate} target="_blank" rel="noopener noreferrer" class="text-sm text-aam-blue font-medium hover:underline mt-1 inline-block">
              View Certificate (PDF) →
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- History Timeline — vertical alternating -->
  <section class="py-20 md:py-24 bg-aam-blue relative overflow-hidden">
    <div class="absolute left-[-100px] top-[-100px] w-[300px] h-[300px] bg-[radial-gradient(circle,rgba(184,134,11,.08),transparent_70%)] pointer-events-none"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 relative z-10">
      <div class="mb-14">
        <span class="inline-block text-xs font-semibold uppercase tracking-widest text-aam-gold bg-aam-gold/10 px-3 py-1.5 rounded-full mb-4">{historyTimeline.eyebrow}</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white -tracking-[0.015em]">{historyTimeline.heading}</h2>
      </div>
      <div class="relative">
        <div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-px bg-white/15 -translate-x-1/2"></div>
        {timeline.map((event, i) => (
          <div class={`flex flex-col md:flex-row items-start ${i % 2 === 0 ? '' : 'md:flex-row-reverse'}`}>
            <div class={`hidden md:flex w-1/2 ${i % 2 === 0 ? 'justify-end pr-8' : 'pl-8'}`}>
              <div class={`bg-white/5 border border-white/10 rounded-xl p-5 max-w-[340px] backdrop-blur-sm hover:bg-white/8 transition-colors ${i % 2 === 0 ? 'text-right' : ''}`}>
                <span class="text-sm text-aam-gold font-semibold font-mono tracking-[0.1em] uppercase block mb-1">{event.period}</span>
                <h4 class="text-xl font-bold text-white mb-1.5">{event.title}</h4>
                <p class="text-sm text-white/70 leading-relaxed">{event.text}</p>
              </div>
            </div>
            <div class="hidden md:flex relative w-0 justify-center">
              <span class="absolute top-6 w-4 h-4 rounded-full bg-aam-gold border-4 border-aam-blue shadow-[0_0_0_2px_rgba(184,134,11,1)]"></span>
            </div>
            <div class="md:hidden w-full pl-6 border-l-2 border-aam-gold/30 pb-8 relative">
              <span class="absolute -left-[9px] top-0 w-4 h-4 rounded-full bg-aam-gold border-4 border-aam-blue shadow-[0_0_0_2px_rgba(184,134,11,1)]"></span>
              <span class="text-xs text-aam-gold font-semibold font-mono tracking-[0.1em] uppercase block mb-2">{event.period}</span>
              <h4 class="text-lg font-bold text-white mb-1.5">{event.title}</h4>
              <p class="text-sm text-white/70 leading-relaxed">{event.text}</p>
            </div>
            <div class="hidden md:block w-1/2"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="py-20 md:py-24 bg-surface-soft">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl font-bold text-slate-900 mb-6">{closingCta.heading}</h2>
      <a href="/contact" class="inline-flex items-center gap-2 bg-aam-blue text-white px-8 py-3.5 rounded-md font-semibold text-sm hover:bg-aam-blue-dark transition-colors">{closingCta.cta}</a>
    </div>
  </section>

  <Footer lang={lang} />
</Layout>
