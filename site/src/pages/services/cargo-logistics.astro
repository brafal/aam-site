---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { cargoLogistics as page } from '../../data/pages/services';
import { defaultLocale } from '../../data/i18n';

const lang = defaultLocale;
---

<Layout title={page.meta.title} description={page.meta.description}>
  <Nav lang={lang} />
  <section class="bg-surface-soft py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 -tracking-[0.025em] mb-2">{page.hero.heading}</h1>
      <p class="text-sm text-slate-400 font-mono tracking-[0.1em] uppercase mb-4">{page.hero.providerLine}</p>
      <p class="text-lg text-slate-500 max-w-[640px]">{page.hero.intro}</p>
    </div>
  </section>
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
        {page.sections.map(section => (
          <div class="bg-surface-soft rounded-xl p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-3">{section.heading}</h3>
            <p class="text-[15px] text-slate-600 leading-relaxed">{section.text}</p>
          </div>
        ))}
      </div>
      <div class="bg-surface-soft rounded-xl p-6">
        <h3 class="text-lg font-bold text-slate-900 mb-3">Available At</h3>
        <div class="grid sm:grid-cols-2 gap-4 text-sm text-slate-600">
          <div><strong class="text-slate-900">SKP</strong> — {page.skp}</div>
          <div><strong class="text-slate-900">OHD</strong> — {page.ohd}</div>
        </div>
      </div>
    </div>
  </section>
  <section class="py-20 md:py-24 bg-aam-blue relative overflow-hidden">
    <div class="absolute right-[-80px] top-[-80px] w-[260px] h-[260px] bg-[radial-gradient(circle,rgba(184,134,11,.2),transparent_70%)] pointer-events-none"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 relative z-10">
      <h2 class="text-3xl md:text-4xl font-bold text-white -tracking-[0.02em] mb-4">Work with AAM Airport Services</h2>
      <a href="/contact?reason=airline-partnership" class="inline-flex items-center gap-2 bg-white text-aam-blue px-6 py-3.5 rounded-lg font-semibold text-sm hover:bg-slate-100 transition-colors">Get in Touch</a>
    </div>
  </section>
  <Footer lang={lang} />
</Layout>
