---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { groundHandling as page } from '../../data/pages/services';
import { defaultLocale } from '../../data/i18n';

const lang = defaultLocale;
---

<Layout title={page.meta.title} description={page.meta.description}>
  <Nav lang={lang} />

  <!-- Hero image -->
  <section class="relative h-[380px] bg-slate-900 overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image:url('/images/airport-handling.webp')"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-black/30"></div>
    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 h-full flex items-end pb-12">
      <div>
        <h1 class="text-4xl md:text-5xl font-bold text-white -tracking-[0.02em] mb-3 max-w-[700px] [text-shadow:0_1px_4px_rgba(0,0,0,0.5)]">{page.hero.heading}</h1>
        <p class="text-base md:text-lg text-white/80 max-w-[640px] mb-6 [text-shadow:0_1px_3px_rgba(0,0,0,0.5)]">{page.hero.intro}</p>
        <a href="/services/ground-handling-request" class="inline-flex items-center gap-2 bg-white text-aam-blue px-6 py-3.5 rounded-lg font-semibold text-sm hover:bg-slate-100 transition-colors">Request Service</a>
      </div>
    </div>
  </section>

  <section class="py-10 md:py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-bold text-slate-900 mb-4">{page.body.heading}</h2>
      <p class="text-base text-slate-600 leading-relaxed mb-8">{page.body.text}</p>

      <h3 class="text-xl font-bold text-slate-900 mb-4">{'What\'s Included'}</h3>
      <ul class="space-y-2 mb-10">
        {page.body.items.map(item => (
          <li class="flex items-start gap-3 text-[15px] text-slate-600">
            <svg class="w-4 h-4 text-aam-gold shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            {item}
          </li>
        ))}
      </ul>

      <div class="bg-surface-soft rounded-xl p-6 mb-10">
        <h3 class="text-lg font-bold text-slate-900 mb-3">Where We Provide Ground Handling Supervision</h3>
        <div class="grid sm:grid-cols-2 gap-4 text-sm text-slate-600">
          <div><strong class="text-slate-900">SKP</strong> — {page.body.skp}</div>
          <div><strong class="text-slate-900">OHD</strong> — {page.body.ohd}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="py-8 md:py-11 bg-aam-blue relative overflow-hidden">
    <div class="absolute right-[-80px] top-[-80px] w-[260px] h-[260px] bg-[radial-gradient(circle,rgba(184,134,11,.18),transparent_70%)] pointer-events-none"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 relative z-10 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white -tracking-[0.015em] mb-4">Need Ground Handling Supervision at SKP or OHD?</h2>
      <p class="text-lg text-white/70 mb-8 max-w-[640px] mx-auto">Submit your flight details and service requirements — our ops team responds within 2 hours.</p>
      <a href="/services/ground-handling-request" class="inline-flex items-center gap-2 bg-white text-aam-blue px-8 py-3.5 rounded-md font-semibold text-sm hover:bg-slate-100 transition-colors">
        Request Ground Handling Supervision & Ground Support →
      </a>
    </div>
  </section>

  <Footer lang={lang} />
</Layout>
