---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { defaultLocale } from '../../data/i18n';
import { WEB3FORMS_KEY as web3formsKey } from '../../data/env';

const lang = defaultLocale;
---

<Layout title="Ground Handling Supervision Request — AAM Airport Services" description="Submit your ground handling supervision requirements for SKP or OHD.">
  <Nav lang={lang} />

  <section class="bg-surface-soft py-14 md:py-18">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="mb-8">
        <span class="inline-block text-xs font-semibold uppercase tracking-widest text-aam-blue bg-aam-blue-light px-3 py-1.5 rounded-full mb-4">
          Ground Handling Supervision & Ground Support
        </span>
        <h1 class="text-3xl md:text-4xl font-bold text-slate-900 -tracking-[0.015em] mb-4">Request Ground Handling Supervision</h1>
        <div class="bg-white border border-slate-200 rounded-xl p-6 text-base text-slate-600 leading-relaxed space-y-3">
          <p>Dear customer,</p>
          <p>Our team works to ensure consistent quality and individual care on the ground.</p>
          <p>To enable this high standard in service, we kindly ask you to give us as detailed information as possible.</p>
          <p>We look forward to serving you and thank you for your cooperation!</p>
        </div>
      </div>

      <form id="gh-form" action="https://api.web3forms.com/submit" method="POST" class="bg-white border border-slate-200 rounded-xl p-8">
        <input type="hidden" name="access_key" value={web3formsKey} />
        <input type="hidden" name="subject" value="AAM Web Form — Ground Handling Supervision Request" />
        <input type="hidden" name="from_name" value="AAM Ground Handling Supervision" />
        <input type="checkbox" name="botcheck" class="honeypot" tabindex="-1" autocomplete="off" />

        <!-- Aircraft Details -->
        <fieldset class="mb-6">
          <legend class="text-lg font-bold text-slate-900 mb-4 pb-2 border-b border-slate-200 w-full">Aircraft Details</legend>
          <div class="grid sm:grid-cols-2 gap-4 mb-4">
            <div>
              <label for="request_status" class="block text-sm font-semibold text-slate-700 mb-1.5">Status of Request *</label>
              <select id="request_status" name="request_status" required class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-aam-blue/20 focus:border-aam-blue transition-colors">
                <option value="">Select status</option>
                <option value="new">New</option>
                <option value="revised">Revised</option>
                <option value="cancelled">Cancelled</option>
              </select>
            </div>
            <div>
            <div>
              <label for="registration" class="block text-sm font-semibold text-slate-700 mb-1.5">Registration *</label>
              <input type="text" id="registration" name="registration" required class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-aam-blue/20 focus:border-aam-blue transition-colors" placeholder="e.g. 9A-BTC" />
            </div>
            <div>
              <label for="aircraft_type" class="block text-sm font-semibold text-slate-700 mb-1.5">Aircraft Type *</label>
              <input type="text" id="aircraft_type" name="aircraft_type" required class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-aam-blue/20 focus:border-aam-blue transition-colors" placeholder="e.g. A320, B737" />
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-4 mb-4">
            <div>
              <label for="mtow" class="block text-sm font-semibold text-slate-700 mb-1.5">MTOW (kg) *</label>
              <input type="number" id="mtow" name="mtow" required class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-aam-blue/20 focus:border-aam-blue transition-colors" placeholder="e.g. 77000" />
            </div>
            <div>
              <label for="operator" class="block text-sm font-semibold text-slate-700 mb-1.5">Operator / Company *</label>
              <input type="text" id="operator" name="operator" required class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-aam-blue/20 focus:border-aam-blue transition-colors" placeholder="Airline or operator name" />
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="flight_number" class="block text-sm font-semibold text-slate-700 mb-1.5">Flight Number</label>
              <input type="text" id="flight_number" name="flight_number" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-aam-blue/20 focus:border-aam-blue transition-colors" placeholder="e.g. WK123" />
            </div>
            <div>
              <label for="flight_category" class="block text-sm font-semibold text-slate-700 mb-1.5">Category of Flight *</label>
              <select id="flight_category" name="flight_category" required class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-aam-blue/20 focus:border-aam-blue transition-colors">
                <option value="">Select category</option>
                <option value="private">Private</option>
                <option value="commercial">Commercial</option>
                <option value="medical">Medical</option>
                <option value="tech_stop">Tech Stop</option>
                <option value="government">Government</option>
                <option value="military">Military</option>
              </select>
            </div>
          </div>
        </fieldset>

        <!-- Arrival -->
        <fieldset class="mb-6">
          <legend class="text-lg font-bold text-slate-900 mb-4 pb-2 border-b border-slate-200 w-full">Arrival</legend>
          <div class="grid sm:grid-cols-2 gap-4 mb-4">
            <div>
              <label for="arr_date" class="block text-sm font-semibold text-slate-700 mb-1.5">Date (UTC) *</label>
              <input type="date" id="arr_date" name="arr_date" required class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-aam-blue/20 focus:border-aam-blue transition-colors" />
            </div>
            <div>
              <label for="arr_time" class="block text-sm font-semibold text-slate-700 mb-1.5">Time (UTC) *</label>
              <input type="time" id="arr_time" name="arr_time" required class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-aam-blue/20 focus:border-aam-blue transition-colors" />
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-4">
            <div class="autocomplete-wrapper relative">
              <label for="arr_from" class="block text-sm font-semibold text-slate-700 mb-1.5">From *</label>
              <input type="text" id="arr_from" name="arr_from_label" required autocomplete="off" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-aam-blue/20 focus:border-aam-blue transition-colors" placeholder="Search airport..." />
              <input type="hidden" name="arr_from" value="" />
              <ul class="autocomplete-dropdown hidden absolute z-10 w-full mt-1 bg-white border border-slate-200 rounded-lg shadow-lg overflow-hidden max-h-64 overflow-y-auto"></ul>
            </div>
            <div>
              <label for="arr_pax" class="block text-sm font-semibold text-slate-700 mb-1.5">No. of Passengers</label>
              <input type="number" id="arr_pax" name="arr_pax" min="0" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-aam-blue/20 focus:border-aam-blue transition-colors" placeholder="0" />
            </div>
          </div>
        </fieldset>

        <!-- Departure -->
        <fieldset class="mb-6">
          <legend class="text-lg font-bold text-slate-900 mb-4 pb-2 border-b border-slate-200 w-full">Departure</legend>
          <div class="grid sm:grid-cols-2 gap-4 mb-4">
            <div>
              <label for="dep_date" class="block text-sm font-semibold text-slate-700 mb-1.5">Date (UTC) *</label>
              <input type="date" id="dep_date" name="dep_date" required class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-aam-blue/20 focus:border-aam-blue transition-colors" />
            </div>
            <div>
              <label for="dep_time" class="block text-sm font-semibold text-slate-700 mb-1.5">Time (UTC) *</label>
              <input type="time" id="dep_time" name="dep_time" required class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-aam-blue/20 focus:border-aam-blue transition-colors" />
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-4">
            <div class="autocomplete-wrapper relative">
              <label for="dep_to" class="block text-sm font-semibold text-slate-700 mb-1.5">To *</label>
              <input type="text" id="dep_to" name="dep_to_label" required autocomplete="off" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-aam-blue/20 focus:border-aam-blue transition-colors" placeholder="Search airport..." />
              <input type="hidden" name="dep_to" value="" />
              <ul class="autocomplete-dropdown hidden absolute z-10 w-full mt-1 bg-white border border-slate-200 rounded-lg shadow-lg overflow-hidden max-h-64 overflow-y-auto"></ul>
            </div>
            <div>
              <label for="dep_pax" class="block text-sm font-semibold text-slate-700 mb-1.5">No. of Passengers</label>
              <input type="number" id="dep_pax" name="dep_pax" min="0" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-aam-blue/20 focus:border-aam-blue transition-colors" placeholder="0" />
            </div>
          </div>
        </fieldset>

        <!-- Services Required -->
        <fieldset class="mb-6">
          <legend class="text-lg font-bold text-slate-900 mb-4 pb-2 border-b border-slate-200 w-full">Services Required</legend>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            {[
              'Crew Transportation', 'Pax Transportation', 'Catering',
              'Crew Hotel', 'Fuel', 'Meteo & Notams',
              'Toilet Service', 'Water Service', 'GPU',
              'Air Starter', 'VIP Lounge',
            ].map(svc => (
              <label class="flex items-center gap-2 text-sm text-slate-700 cursor-pointer">
                <input type="checkbox" name="services" value={svc} class="w-4 h-4 rounded border-slate-300 text-aam-blue focus:ring-aam-blue/20" />
                {svc}
              </label>
            ))}
          </div>
        </fieldset>

        <!-- Contact -->
        <fieldset class="mb-6">
          <legend class="text-lg font-bold text-slate-900 mb-4 pb-2 border-b border-slate-200 w-full">Contact Information</legend>
          <div class="grid sm:grid-cols-2 gap-4 mb-4">
            <div>
              <label for="contact_name" class="block text-sm font-semibold text-slate-700 mb-1.5">Name *</label>
              <input type="text" id="contact_name" name="contact_name" required class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-aam-blue/20 focus:border-aam-blue transition-colors" placeholder="Your name" />
            </div>
            <div>
              <label for="contact_company" class="block text-sm font-semibold text-slate-700 mb-1.5">Broker / Company</label>
              <input type="text" id="contact_company" name="contact_company" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-aam-blue/20 focus:border-aam-blue transition-colors" placeholder="Company name" />
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-4 mb-4">
            <div>
              <label for="contact_email" class="block text-sm font-semibold text-slate-700 mb-1.5">E-Mail *</label>
              <input type="email" id="contact_email" name="contact_email" required class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-aam-blue/20 focus:border-aam-blue transition-colors" placeholder="you@example.com" />
            </div>
            <div>
              <label for="contact_phone" class="block text-sm font-semibold text-slate-700 mb-1.5">Phone</label>
              <input type="tel" id="contact_phone" name="contact_phone" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-aam-blue/20 focus:border-aam-blue transition-colors" placeholder="+389 ..." />
            </div>
          </div>
          <div>
            <label for="contact_message" class="block text-sm font-semibold text-slate-700 mb-1.5">Message</label>
            <textarea id="contact_message" name="contact_message" rows="3" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-aam-blue/20 focus:border-aam-blue transition-colors resize-y" placeholder="Additional notes or special requirements"></textarea>
          </div>
        </fieldset>

        <button type="submit" class="inline-flex items-center gap-2 bg-aam-blue text-white px-8 py-3 rounded-md font-semibold text-sm hover:bg-aam-blue-dark transition-colors">
          Submit Request →
        </button>
        <p id="form-result" class="hidden mt-4 text-sm font-medium"></p>
      </form>
    </div>
  </section>

  <!-- Web3Forms + Airport Autocomplete -->
  <script>
    const form = document.getElementById('gh-form');
    const result = document.getElementById('form-result');

    // ── Airport Autocomplete ──────────────────────────────────────────
    let airports = [];
    let activeWrappers = [];

    (async function initAutocomplete() {
      try {
        const res = await fetch('/data/airports.json');
        const data = await res.json();
        airports = Object.values(data).filter(a => a.iata);
      } catch (e) {
        console.warn('Airport data failed to load', e);
      }
      document.querySelectorAll('.autocomplete-wrapper').forEach(buildAutocomplete);
    })();

    function buildAutocomplete(wrapper) {
      const input = wrapper.querySelector('input[type="text"]');
      const hidden = wrapper.querySelector('input[type="hidden"]');
      const dropdown = wrapper.querySelector('.autocomplete-dropdown');
      let idx = -1;
      activeWrappers.push(wrapper);

      input.addEventListener('input', () => {
        const q = input.value.trim();
        if (q.length < 3) { dropdown.classList.add('hidden'); return; }
        const re = new RegExp(q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'i');
        const matches = airports.filter(a => re.test(a.iata) || re.test(a.name) || re.test(a.city) || re.test(a.icao)).slice(0, 8);
        idx = -1;
        dropdown.innerHTML = matches.map((a, i) =>
          `<li data-i="${i}" class="autocomplete-item px-4 py-2.5 text-sm text-slate-700 hover:bg-aam-blue-light cursor-pointer transition-colors border-b border-slate-100 last:border-b-0">${a.city || ''} — ${a.name} (${a.iata})</li>`
        ).join('');
        dropdown.classList.toggle('hidden', matches.length === 0);
      });

      input.addEventListener('keydown', (e) => {
        const items = dropdown.querySelectorAll('.autocomplete-item');
        if (e.key === 'ArrowDown') { e.preventDefault(); idx = Math.min(idx + 1, items.length - 1); highlight(items, idx); }
        else if (e.key === 'ArrowUp') { e.preventDefault(); idx = Math.max(idx - 1, 0); highlight(items, idx); }
        else if (e.key === 'Enter') { e.preventDefault(); if (idx >= 0 && items[idx]) items[idx].click(); }
        else if (e.key === 'Escape') { dropdown.classList.add('hidden'); idx = -1; }
      });

      dropdown.addEventListener('click', (e) => {
        const li = e.target.closest('.autocomplete-item');
        if (!li) return;
        const match = li.textContent.match(/\((.*?)\)$/);
        if (!match) return;
        const iata = match[1];
        const ap = airports.find(a => a.iata === iata);
        if (!ap) return;
        input.value = `${ap.city || ''} — ${ap.name} (${ap.iata})`;
        hidden.value = ap.iata;
        dropdown.classList.add('hidden');
        idx = -1;
      });

      input.addEventListener('blur', () => { setTimeout(() => dropdown.classList.add('hidden'), 150); });
      input.addEventListener('focus', () => { if (input.value.trim().length >= 3) { const ev = new Event('input'); input.dispatchEvent(ev); } });

      function highlight(items, i) {
        items.forEach((el, j) => el.classList.toggle('bg-aam-blue-light', j === i));
      }
    }

    // ── Form submission ──────────────────────────────────────────────
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]');
      btn.disabled = true;
      btn.textContent = 'Sending...';
      result.classList.add('hidden');
      try {
        const res = await fetch(form.action, { method: 'POST', body: new FormData(form) });
        const data = await res.json();
        if (data.success) {
          result.textContent = 'Thank you — your request has been sent. Our ops team will respond within 2 hours.';
          result.classList.remove('hidden', 'text-red-600');
          result.classList.add('text-green-600');
          form.reset();
          // clear autocomplete hidden inputs
          form.querySelectorAll('.autocomplete-wrapper input[type="hidden"]').forEach(h => h.value = '');

        } else {
          throw new Error(data.message || 'Submission failed');
        }
      } catch (err) {
        result.textContent = 'Something went wrong. Please contact us directly at ' + atob('YWFtaW5mb0BhYW0uY29tLm1r') + '.';
        result.classList.remove('hidden', 'text-green-600');
        result.classList.add('text-red-600');
      }
      btn.disabled = false;
      btn.textContent = 'Submit Request →';
    });
  </script>

  <Footer lang={lang} />
</Layout>
