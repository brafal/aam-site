---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { defaultLocale } from '../data/i18n';

const lang = defaultLocale;
---

<Layout title="Privacy Policy | AAM Airport Services" description="Privacy policy for AAM Airport Services.">
  <Nav lang={lang} />

  <section class="bg-surface-soft py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 -tracking-[0.025em]">Privacy Policy</h1>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <p class="text-base text-slate-600 leading-relaxed">
        This page will be updated shortly. For questions: <a href="#" class="em-link text-aam-blue hover:underline" data-u="YWFtaW5mbw==" data-d="YWFtLmNvbS5taw==" data-em-label="1">&#97;&#97;&#109;&#105;&#110;&#102;&#111;&#64;&#97;&#97;&#109;&#46;&#99;&#111;&#109;&#46;&#109;&#107;</a>.
      </p>
    </div>
  </section>

  <Footer lang={lang} />
</Layout>
