---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { defaultLocale } from '../data/i18n';

const lang = defaultLocale;
---

<Layout title="Terms of Use | AAM Airport Services" description="Terms of use for AAM Airport Services.">
  <Nav lang={lang} />

  <section class="bg-surface-soft py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 -tracking-[0.025em]">Terms of Use</h1>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <p class="text-base text-slate-600 leading-relaxed">
        This page will be updated shortly. For questions: <a href="mailto:aaminfo@aam.com.mk" class="text-aam-blue hover:underline">aaminfo@aam.com.mk</a>.
      </p>
    </div>
  </section>

  <Footer lang={lang} />
</Layout>
